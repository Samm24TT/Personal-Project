# ==============================================================================
# Unreal Engine .gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# Unreal Engine — Build & Intermediate Artifacts
# ------------------------------------------------------------------------------
Binaries/
Intermediate/
DerivedDataCache/
Saved/

# ------------------------------------------------------------------------------
# Unreal Engine — Generated Project Files
# ------------------------------------------------------------------------------
*.sln
*.suo
*.vcxproj
*.vcxproj.filters
*.vcxproj.user

# ------------------------------------------------------------------------------
# Visual Studio
# ------------------------------------------------------------------------------
.vs/
*.opensdf
*.sdf
*.VC.db
*.VC.VC.opendb
*.ipch

# ------------------------------------------------------------------------------
# Visual Studio Code
# ------------------------------------------------------------------------------
.vscode/*
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/c_cpp_properties.json

# JetBrains Rider
# ------------------------------------------------------------------------------
.idea/
*.sln.DotSettings.user

# ------------------------------------------------------------------------------
# Xcode (macOS)
# ------------------------------------------------------------------------------
*.xcworkspace
*.xcuserstate
*.xcuserdata
DerivedData/

# ------------------------------------------------------------------------------
# OS-Generated Files
# ------------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ------------------------------------------------------------------------------
# Packaging & Distribution
# ------------------------------------------------------------------------------
Build/
*.pak
*.exe
*.ipa
*.apk
*.obb

# ------------------------------------------------------------------------------
# Crash & Log Files
# ------------------------------------------------------------------------------
*.log
CrashReportClient/

# ------------------------------------------------------------------------------
# Content (optional — uncomment if you version content via source control)
# ------------------------------------------------------------------------------
# Content/ (Only ignore if you use a separate content repository or pack)

# ------------------------------------------------------------------------------
# Plugins — ignore compiled binaries, keep source
# ------------------------------------------------------------------------------
Plugins/*/Binaries/
Plugins/*/Intermediate/

# ------------------------------------------------------------------------------
# Configuration overrides (local settings per developer)
# ------------------------------------------------------------------------------
Config/*.ini
!Config/Default*.ini
!Config/Default*.ini.example

# ------------------------------------------------------------------------------
# Misc
# ------------------------------------------------------------------------------
*.tmp
*.bak
*.swp
*~
